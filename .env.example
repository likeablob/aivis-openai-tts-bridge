# Aivis OpenAI TTS Bridge Configuration
# Copy this to .env and modify as needed

# AivisSpeech Engine URL (default: localhost:10101)
# AIVIS__URL=http://localhost:10101

# Default voice when not specified (default: auto)
# - "auto": first available voice
# - speaker name: e.g. "まお"
# - style_id: e.g. "559422240"
# AIVIS__DEFAULT_VOICE=auto

# Server Settings
SERVER__HOST=0.0.0.0
SERVER__PORT=10201
SERVER__DEBUG=false
SERVER__API_KEY=your-secret-api-key
